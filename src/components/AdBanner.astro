---
import { getAdsSettings } from '../lib/queries.js';

interface Props {
  position: 'sidebar' | 'top';
}

const { position } = Astro.props;

let adsSettings: any = {};
try {
  adsSettings = await getAdsSettings();
} catch (e) {
  // DB error fallback
  adsSettings = {};
}

const isActive = position === 'sidebar' ? adsSettings.ad_sidebar_active === '1' : adsSettings.ad_top_active === '1';
const imageUrl = position === 'sidebar' ? adsSettings.ad_sidebar_image : adsSettings.ad_top_image;
const targetLink = position === 'sidebar' ? adsSettings.ad_sidebar_link : adsSettings.ad_top_link;
---

{isActive && imageUrl && (
<div class={`ad-banner-container ${position === 'top' ? 'mb-8' : 'mb-6'}`}>
  <div class="flex items-center gap-2 mb-2">
    <span class="text-[10px] uppercase font-black tracking-widest text-slate-500 bg-slate-800/50 px-2 py-0.5 rounded-full">Sponsored</span>
  </div>
  <a href={targetLink || '#'} target="_blank" rel="noopener noreferrer" class="block rounded-xl overflow-hidden border border-[#1e2d3d] hover:border-green-500/50 transition-colors shadow-lg shadow-black/50">
    <img 
      src={imageUrl} 
      alt="Advertisement" 
      class={`w-full object-cover bg-[#0b1120] ${position === 'sidebar' ? 'aspect-[300/250] md:aspect-[300/600] max-h-[600px]' : 'aspect-[728/90]'}`}
      loading="lazy"
      onerror="this.style.display='none'"
    />
  </a>
</div>
)}
