---
import { verifySession } from '../../lib/auth.js';

const session = await verifySession(Astro.request);
if (session) return Astro.redirect('/admin/dashboard');
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Daftar Admin — Regular Investor</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0b1120; font-family: 'Inter', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card { background: #151f2e; border: 1px solid #1e2d3d; border-radius: 20px; padding: 40px; width: 100%; max-width: 420px; }
    .logo { display: flex; align-items: center; gap: 10px; margin-bottom: 32px; }
    .logo-text { font-size: 20px; font-weight: 900; color: #fff; }
    .logo-text span { background: linear-gradient(135deg, #3b82f6, #22c55e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .logo-sub { font-size: 10px; color: #64748b; letter-spacing: 0.1em; text-transform: uppercase; }
    h1 { color: #fff; font-size: 22px; font-weight: 900; margin-bottom: 6px; }
    .subtitle { color: #64748b; font-size: 13px; margin-bottom: 28px; }
    label { display: block; font-size: 11px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
    input { width: 100%; background: #0b1120; border: 1px solid #1e2d3d; border-radius: 12px; padding: 12px 16px; font-size: 14px; color: #e2e8f0; outline: none; transition: border-color 0.15s; margin-bottom: 20px; font-family: inherit; }
    input:focus { border-color: rgba(59,130,246,0.5); }
    .msg { font-size: 12px; padding: 10px 14px; border-radius: 10px; margin-bottom: 20px; display: none; }
    .msg.error { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: #f87171; }
    .msg.success { background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); color: #4ade80; }
    .msg.show { display: block; }
    button { width: 100%; background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff; font-weight: 900; font-size: 14px; padding: 14px; border: none; border-radius: 12px; cursor: pointer; transition: opacity 0.15s; font-family: inherit; }
    button:hover { opacity: 0.9; }
    button:disabled { opacity: 0.5; cursor: not-allowed; }
    .login-link { text-align: center; margin-top: 20px; }
    .login-link a { color: #22c55e; font-size: 13px; font-weight: 600; text-decoration: none; transition: opacity 0.15s; }
    .login-link a:hover { opacity: 0.8; }
    .info-box { background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.15); border-radius: 10px; padding: 12px 14px; margin-bottom: 24px; }
    .info-box p { color: #93c5fd; font-size: 11px; line-height: 1.6; }
    .info-box strong { color: #60a5fa; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <svg viewBox="0 0 40 40" width="36" height="36" fill="none">
        <circle cx="20" cy="20" r="19" stroke="url(#g)" stroke-width="2"/>
        <rect x="10" y="24" width="4" height="8" rx="1" fill="#dc2626"/>
        <rect x="16" y="19" width="4" height="13" rx="1" fill="#dc2626"/>
        <rect x="22" y="14" width="4" height="18" rx="1" fill="#dc2626"/>
        <path d="M9 28 Q20 8 33 10" stroke="url(#ag)" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <path d="M29 7 L33 10 L30 14" stroke="#22c55e" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        <defs>
          <linearGradient id="g" x1="0" y1="0" x2="40" y2="40"><stop offset="0%" stop-color="#3b82f6"/><stop offset="100%" stop-color="#22c55e"/></linearGradient>
          <linearGradient id="ag" x1="0" y1="0" x2="40" y2="0"><stop offset="0%" stop-color="#3b82f6"/><stop offset="100%" stop-color="#22c55e"/></linearGradient>
        </defs>
      </svg>
      <div>
        <div class="logo-text"><span>Regular</span> Investor</div>
        <div class="logo-sub">Admin Registration</div>
      </div>
    </div>

    <h1>Daftar Admin Baru</h1>
    <p class="subtitle">Buat akun admin untuk mengelola konten</p>

    <div class="info-box">
      <p>📌 <strong>Admin pertama</strong> otomatis aktif. Pendaftaran berikutnya memerlukan <strong>persetujuan admin</strong> yang sudah aktif.</p>
    </div>

    <div class="msg" id="msgBox"></div>

    <form id="registerForm">
      <label for="name">Nama Lengkap</label>
      <input type="text" id="name" placeholder="John Doe" autocomplete="name" required/>
      <label for="email">Email (Google Email)</label>
      <input type="email" id="email" placeholder="nama@gmail.com" autocomplete="email" required/>
      <label for="password">Password</label>
      <input type="password" id="password" placeholder="Minimal 6 karakter" autocomplete="new-password" required minlength="6"/>
      <label for="confirmPassword">Konfirmasi Password</label>
      <input type="password" id="confirmPassword" placeholder="Ulangi password" autocomplete="new-password" required/>
      <button type="submit" id="registerBtn">Daftar Sekarang →</button>
    </form>

    <div class="login-link">
      <p style="color: #475569; font-size: 12px; margin-bottom: 6px;">Sudah punya akun?</p>
      <a href="/admin">← Kembali ke Login</a>
    </div>
  </div>

  <script>
    document.getElementById('registerForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('registerBtn') as HTMLButtonElement;
      const msg = document.getElementById('msgBox')!;
      const name = (document.getElementById('name') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const confirmPwd = (document.getElementById('confirmPassword') as HTMLInputElement).value;

      msg.classList.remove('show', 'error', 'success');

      if (password !== confirmPwd) {
        msg.textContent = 'Password dan konfirmasi password tidak cocok.';
        msg.classList.add('show', 'error');
        return;
      }

      if (password.length < 6) {
        msg.textContent = 'Password minimal 6 karakter.';
        msg.classList.add('show', 'error');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Memproses...';

      try {
        const res = await fetch('/api/admin/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password, name }),
        });
        const data = await res.json();

        if (res.ok) {
          msg.textContent = data.message;
          msg.classList.add('show', 'success');
          btn.textContent = 'Berhasil ✓';
          // Redirect to login after 2 seconds if active
          if (data.status === 'active') {
            setTimeout(() => { window.location.href = '/admin'; }, 2000);
          }
        } else {
          msg.textContent = data.error || 'Registrasi gagal.';
          msg.classList.add('show', 'error');
          btn.disabled = false;
          btn.textContent = 'Daftar Sekarang →';
        }
      } catch {
        msg.textContent = 'Gagal terhubung ke server.';
        msg.classList.add('show', 'error');
        btn.disabled = false;
        btn.textContent = 'Daftar Sekarang →';
      }
    });
  </script>
</body>
</html>
