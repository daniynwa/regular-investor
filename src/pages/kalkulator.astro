<!-- Chart.js from CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
  // ══════════════════════════════════════════════════════════════════════════
  // BUNGA MAJEMUK CALCULATOR (with chart & variance)
  // ══════════════════════════════════════════════════════════════════════════
  let freq = 12;
  let chart: any = null;

  const $ = (id: string) => document.getElementById(id) as HTMLInputElement;
  const val = (id: string) => parseFloat(($(id) as HTMLInputElement).value) || 0;

  function fmtRp(n: number): string {
    if (Math.abs(n) >= 1e12) return 'Rp ' + (n / 1e12).toFixed(2) + ' T';
    if (Math.abs(n) >= 1e9)  return 'Rp ' + (n / 1e9).toFixed(2)  + ' M';
    if (Math.abs(n) >= 1e6)  return 'Rp ' + (n / 1e6).toFixed(2)  + ' jt';
    return 'Rp ' + Math.round(n).toLocaleString('id-ID');
  }

  function fmtTable(n: number): string { return Math.round(n).toLocaleString('id-ID'); }

  function calcYear(P: number, pmt: number, r: number, n: number, t: number) {
    const rn = r / 100 / n;
    const periods = n * t;
    const fvP   = P * Math.pow(1 + rn, periods);
    const fvPmt = rn > 0 ? pmt * ((Math.pow(1 + rn, periods) - 1) / rn) : pmt * periods;
    return fvP + fvPmt;
  }

  function calcSchedule(P: number, pmt: number, r: number, n: number, years: number) {
    const rows = [];
    for (let t = 1; t <= years; t++) {
      const endBal = calcYear(P, pmt, r, n, t);
      const totalContribActual = pmt * 12 * t;
      const interest = endBal - P - totalContribActual;
      rows.push({ year: t, endBal, totalContrib: totalContribActual, interest });
    }
    return rows;
  }

  function syncSlider(inputId: string, rangeId: string) {
    const inp = $(inputId) as HTMLInputElement;
    const rng = $(rangeId) as HTMLInputElement;
    inp.addEventListener('input', () => { rng.value = inp.value; calculate(); });
    rng.addEventListener('input', () => { inp.value = rng.value; calculate(); });
  }
  syncSlider('principal', 'principalRange');
  syncSlider('monthly', 'monthlyRange');
  syncSlider('years', 'yearsRange');
  syncSlider('rate', 'rateRange');

  document.querySelectorAll('.freq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.freq-btn').forEach(b => {
        b.className = 'freq-btn text-[10px] font-semibold py-2 rounded-lg border transition-all bg-[#0b1120] text-slate-500 border-[#1e2d3d] hover:text-slate-300';
      });
      btn.className = 'freq-btn text-[10px] font-semibold py-2 rounded-lg border transition-all bg-rose-500/15 text-rose-400 border-rose-500/30';
      freq = parseInt((btn as HTMLElement).dataset.freq || '12');
      calculate();
    });
  });

  function calculate() {
    const P = val('principal'), pmt = val('monthly');
    const years = Math.max(1, Math.min(50, val('years'))), r = val('rate');
    const varianceEnabled = (document.getElementById('varianceToggle') as HTMLInputElement)?.checked;
    const variance = varianceEnabled ? val('variance') : 0;
    const schedule = calcSchedule(P, pmt, r, freq, years);
    const final = schedule[schedule.length - 1]?.endBal ?? 0;
    const totalContrib = pmt * 12 * years;
    const totalInterest = final - P - totalContrib;
    $('outFinal').textContent = fmtRp(final);
    $('outPrincipal').textContent = fmtRp(P);
    $('outContrib').textContent = fmtRp(totalContrib);
    $('outInterest').textContent = fmtRp(totalInterest);
    renderChart(schedule, P, pmt);
    renderTable(schedule);
    if (variance > 0) renderVariance(P, pmt, r, freq, years, variance);
    else document.getElementById('varianceSection')!.classList.add('hidden');
    document.getElementById('chartPlaceholder')!.classList.add('hidden');
    document.getElementById('tableSection')!.classList.remove('hidden');
  }

  function renderChart(schedule: any[], P: number, pmt: number) {
    const labels = schedule.map(r => `Thn ${r.year}`);
    const prinArr = schedule.map(() => P);
    const ctbArr = schedule.map(r => Math.max(0, pmt * 12 * r.year));
    const intArr = schedule.map(r => Math.max(0, r.endBal - P - pmt * 12 * r.year));
    const ctx = (document.getElementById('growthChart') as HTMLCanvasElement).getContext('2d')!;
    if (chart) chart.destroy();
    chart = new (window as any).Chart(ctx, {
      type: 'bar', data: { labels, datasets: [
        { label: 'Modal Awal', data: prinArr, backgroundColor: 'rgba(59,130,246,0.75)', borderRadius: 4, borderSkipped: false },
        { label: 'Total Kontribusi', data: ctbArr, backgroundColor: 'rgba(168,85,247,0.75)', borderRadius: 0, borderSkipped: false },
        { label: 'Bunga Majemuk', data: intArr, backgroundColor: 'rgba(34,197,94,0.85)', borderRadius: { topLeft: 4, topRight: 4, bottomLeft: 0, bottomRight: 0 }, borderSkipped: false },
      ]},
      options: { responsive: true, maintainAspectRatio: false, interaction: { mode: 'index', intersect: false },
        plugins: { legend: { display: false }, tooltip: { backgroundColor: '#111827', borderColor: '#1e2d3d', borderWidth: 1, titleColor: '#94a3b8', bodyColor: '#e2e8f0', padding: 12, callbacks: { label: (ctx: any) => ` ${ctx.dataset.label}: ${fmtRp(ctx.raw)}` } } },
        scales: { x: { stacked: true, grid: { color: 'rgba(30,45,61,0.5)' }, ticks: { color: '#475569', font: { size: 10 } } }, y: { stacked: true, grid: { color: 'rgba(30,45,61,0.5)' }, ticks: { color: '#475569', font: { size: 10 }, callback: (v: any) => fmtRp(v) } } },
      },
    });
  }

  function renderTable(schedule: any[]) {
    const tbody = document.getElementById('yearTable')!;
    tbody.innerHTML = '';
    schedule.forEach((row, i) => {
      const tr = document.createElement('tr');
      tr.className = `border-b border-[#1e2d3d] hover:bg-[#0d1525] transition-colors ${i % 2 === 1 ? 'bg-[#0b1120]/20' : ''}`;
      const isUp = row.interest >= 0;
      tr.innerHTML = `<td class="px-5 py-3 font-semibold text-slate-300">Tahun ${row.year}</td><td class="px-4 py-3 text-right text-purple-300">${fmtTable(row.totalContrib)}</td><td class="px-4 py-3 text-right ${isUp ? 'text-green-400' : 'text-red-400'}">${fmtTable(row.interest)}</td><td class="px-5 py-3 text-right font-bold text-white">${fmtTable(row.endBal)}</td>`;
      tbody.appendChild(tr);
    });
  }

  function renderVariance(P: number, pmt: number, r: number, n: number, years: number, v: number) {
    const section = document.getElementById('varianceSection')!;
    const container = document.getElementById('varianceCards')!;
    section.classList.remove('hidden');
    container.innerHTML = '';
    const scenarios = [
      { rate: r - v, label: `Pesimis (${(r - v).toFixed(1)}%)`, color: 'red' },
      { rate: r, label: `Utama (${r.toFixed(1)}%)`, color: 'green' },
      { rate: r + v, label: `Optimis (${(r + v).toFixed(1)}%)`, color: 'blue' },
    ];
    scenarios.forEach(s => {
      if (s.rate < 0) { container.innerHTML += `<div class="bg-[#0b1120] border border-[#1e2d3d] rounded-xl p-4 text-center"><p class="text-xs text-slate-500">Suku bunga tidak valid</p></div>`; return; }
      const sched = calcSchedule(P, pmt, s.rate, n, years);
      const final = sched[sched.length - 1]?.endBal ?? 0;
      const totalC = pmt * 12 * years, totalI = final - P - totalC;
      const pct = (P + totalC) > 0 ? (totalI / (P + totalC) * 100) : 0;
      const colorMap: Record<string, string> = { red: 'border-red-500/20 bg-red-500/5 text-red-400', green: 'border-green-500/20 bg-green-500/5 text-green-400', blue: 'border-blue-500/20 bg-blue-500/5 text-blue-400' };
      const cc = colorMap[s.color];
      container.innerHTML += `<div class="border ${cc} rounded-xl p-4 text-center"><div class="text-[10px] font-bold uppercase tracking-widest mb-2 ${cc.split(' ')[2]}">${s.label}</div><div class="text-lg font-black text-white mb-1">${fmtRp(final)}</div><div class="text-xs text-slate-500 mb-2">Saldo akhir</div><div class="h-px bg-[#1e2d3d] mb-2"></div><div class="text-xs text-slate-400">Bunga: <span class="${cc.split(' ')[2]} font-semibold">${fmtRp(totalI)}</span></div><div class="text-[10px] text-slate-500 mt-0.5">ROI: ${pct.toFixed(1)}%</div></div>`;
    });
  }

  const varianceToggle = document.getElementById('varianceToggle') as HTMLInputElement;
  const varianceInputWrap = document.getElementById('varianceInputWrap')!;
  const varianceOffHint = document.getElementById('varianceOffHint')!;
  const varianceLabel = document.getElementById('varianceToggleLabel')!;
  varianceToggle?.addEventListener('change', () => {
    const on = varianceToggle.checked;
    varianceInputWrap.classList.toggle('hidden', !on);
    varianceOffHint.classList.toggle('hidden', on);
    varianceLabel.textContent = on ? 'Aktif' : 'Nonaktif';
    varianceLabel.className = on ? 'text-[10px] text-teal-400 font-semibold transition-colors' : 'text-[10px] text-slate-500 group-hover:text-slate-300 transition-colors';
    calculate();
  });
  ['rate', 'variance', 'years'].forEach(id => { $(id)?.addEventListener('input', calculate); });
  document.getElementById('calcBtn')?.addEventListener('click', calculate);
  calculate();

  // ══════════════════════════════════════════════════════════════════════════
  // OTHER CALCULATORS
  // ══════════════════════════════════════════════════════════════════════════
  const fmt = (n: number) => 'Rp ' + Math.round(n).toLocaleString('id-ID');

  // Dividend calculator
  document.getElementById('calcDivBtn')?.addEventListener('click', () => {
    const price = parseFloat((document.getElementById('divPrice') as HTMLInputElement).value) || 0;
    const shares = parseFloat((document.getElementById('divShares') as HTMLInputElement).value) || 0;
    const divAmt = parseFloat((document.getElementById('divAmount') as HTMLInputElement).value) || 0;
    const totalInvest = price * shares, totalDiv = divAmt * shares;
    const yield_ = totalInvest > 0 ? (totalDiv / totalInvest * 100) : 0;
    (document.getElementById('divTotalInvest') as HTMLElement).textContent = fmt(totalInvest);
    (document.getElementById('divTotalDiv') as HTMLElement).textContent = fmt(totalDiv);
    (document.getElementById('divYield') as HTMLElement).textContent = yield_.toFixed(2) + '%';
    document.getElementById('divResult')?.classList.remove('hidden');
  });

  // ── CAGR tab switcher ──────────────────────────────────────────────────────
  function switchCAGRTab(mode: string) {
    const compound = document.getElementById('compoundMode')!;
    const cagr = document.getElementById('cagrMode')!;
    const tabC = document.getElementById('cagrTabCompound')!;
    const tabR = document.getElementById('cagrTabCAGR')!;

    if (mode === 'compound') {
      compound.classList.remove('hidden');
      cagr.classList.add('hidden');
      tabC.className = 'flex-1 text-xs font-semibold py-2 rounded-lg transition-all bg-amber-500/15 text-amber-400 border border-amber-500/30';
      tabR.className = 'flex-1 text-xs font-semibold py-2 rounded-lg transition-all text-slate-500 hover:text-slate-300';
    } else {
      cagr.classList.remove('hidden');
      compound.classList.add('hidden');
      tabR.className = 'flex-1 text-xs font-semibold py-2 rounded-lg transition-all bg-amber-500/15 text-amber-400 border border-amber-500/30';
      tabC.className = 'flex-1 text-xs font-semibold py-2 rounded-lg transition-all text-slate-500 hover:text-slate-300';
    }
  }
  (window as any).switchCAGRTab = switchCAGRTab;

  // ── Compounding calculator (with monthly top-up) ──────────────────────────
  document.getElementById('calcCpBtn')?.addEventListener('click', () => {
    const P   = parseFloat((document.getElementById('cpPrincipal') as HTMLInputElement).value) || 0;
    const pmt = parseFloat((document.getElementById('cpMonthly') as HTMLInputElement).value) || 0;
    const r   = parseFloat((document.getElementById('cpRate') as HTMLInputElement).value) / 100 || 0;
    const t   = parseFloat((document.getElementById('cpYears') as HTMLInputElement).value) || 0;
    const n   = parseFloat((document.getElementById('cpFreq') as HTMLSelectElement).value) || 1;

    // FV of lump sum: P × (1 + r/n)^(n×t)
    const fvLump = P * Math.pow(1 + r / n, n * t);

    // FV of monthly contributions (annuity)
    const monthlyRate = r / 12;
    const totalMonths = t * 12;
    const fvAnnuity = monthlyRate > 0
      ? pmt * ((Math.pow(1 + monthlyRate, totalMonths) - 1) / monthlyRate)
      : pmt * totalMonths;

    const FV = fvLump + fvAnnuity;
    const totalTopup = pmt * totalMonths;
    const totalModal = P + totalTopup;
    const gain = FV - totalModal;
    const multiplier = totalModal > 0 ? FV / totalModal : 0;

    const fmt = (v: number) => 'Rp ' + Math.round(v).toLocaleString('id-ID');

    (document.getElementById('cpPrincipalOut') as HTMLElement).textContent = fmt(P);
    (document.getElementById('cpTotalTopup') as HTMLElement).textContent = fmt(totalTopup);
    (document.getElementById('cpTotalModal') as HTMLElement).textContent = fmt(totalModal);
    (document.getElementById('cpGain') as HTMLElement).textContent = fmt(gain);
    (document.getElementById('cpMultiplier') as HTMLElement).textContent = multiplier.toFixed(2) + '×';
    (document.getElementById('cpFinal') as HTMLElement).textContent = fmt(FV);
    document.getElementById('cpResult')?.classList.remove('hidden');

    // Build yearly breakdown
    const bd = document.getElementById('cpBreakdown')!;
    bd.innerHTML = '';
    for (let y = 1; y <= t; y++) {
      const yvLump = P * Math.pow(1 + r / n, n * y);
      const yvMonths = y * 12;
      const yvAnnuity = monthlyRate > 0
        ? pmt * ((Math.pow(1 + monthlyRate, yvMonths) - 1) / monthlyRate)
        : pmt * yvMonths;
      const yv = yvLump + yvAnnuity;
      const yCumTopup = pmt * yvMonths;
      const yGain = yv - P - yCumTopup;
      const row = document.createElement('div');
      row.className = 'flex justify-between text-xs py-1.5 border-b border-[#1e2d3d]/50';
      row.innerHTML = `
        <span class="text-slate-500">Tahun ${y}</span>
        <span class="text-slate-600 text-[10px]">topup ${fmt(yCumTopup)}</span>
        <span class="text-green-400 text-[10px]">gain ${fmt(yGain)}</span>
        <span class="text-amber-400 font-semibold">${fmt(yv)}</span>`;
      bd.appendChild(row);
    }
  });

  document.getElementById('cpToggleBreakdown')?.addEventListener('click', () => {
    const bd = document.getElementById('cpBreakdown')!;
    const btn = document.getElementById('cpToggleBreakdown')!;
    bd.classList.toggle('hidden');
    btn.textContent = bd.classList.contains('hidden') ? 'Lihat proyeksi per tahun ▾' : 'Sembunyikan proyeksi ▴';
  });

  // ── CAGR calculator ────────────────────────────────────────────────────────
  document.getElementById('calcCAGRBtn')?.addEventListener('click', () => {
    const start = parseFloat((document.getElementById('cagrStart') as HTMLInputElement).value) || 0;
    const end = parseFloat((document.getElementById('cagrEnd') as HTMLInputElement).value) || 0;
    const t = parseFloat((document.getElementById('cagrYears') as HTMLInputElement).value) || 1;
    const cagr = (Math.pow(end / start, 1 / t) - 1) * 100;
    const totalReturn = ((end - start) / start) * 100;
    const absReturn = end - start;
    const up = absReturn >= 0;
    (document.getElementById('cagrTotalReturn') as HTMLElement).textContent = totalReturn.toFixed(2) + '%';
    (document.getElementById('cagrTotalReturn') as HTMLElement).className = `font-semibold ${up ? 'text-amber-400' : 'text-red-400'}`;
    (document.getElementById('cagrAbsReturn') as HTMLElement).textContent = (up ? '+' : '') + fmt(absReturn);
    (document.getElementById('cagrAbsReturn') as HTMLElement).className = `font-semibold ${up ? 'text-white' : 'text-red-400'}`;
    (document.getElementById('cagrRate') as HTMLElement).textContent = cagr.toFixed(2) + '%';
    (document.getElementById('cagrRate') as HTMLElement).className = `font-bold text-xl ${up ? 'text-amber-400' : 'text-red-400'}`;
    document.getElementById('cagrResult')?.classList.remove('hidden');
  });

  // Dividend Yield calculator
  document.getElementById('calcDyBtn')?.addEventListener('click', () => {
    const currentPrice = parseFloat((document.getElementById('dyCurrentPrice') as HTMLInputElement).value) || 0;
    const buyPrice = parseFloat((document.getElementById('dyBuyPrice') as HTMLInputElement).value) || 0;
    const trailing = parseFloat((document.getElementById('dyTrailing') as HTMLInputElement).value) || 0;
    const forward = parseFloat((document.getElementById('dyForward') as HTMLInputElement).value) || 0;
    const shares = parseFloat((document.getElementById('dyShares') as HTMLInputElement).value) || 0;
    const trailingYield = currentPrice > 0 ? (trailing / currentPrice) * 100 : 0;
    const forwardYield = currentPrice > 0 ? (forward / currentPrice) * 100 : 0;
    const yoc = buyPrice > 0 ? (trailing / buyPrice) * 100 : 0;
    const incomeT = trailing * shares, incomeF = forward * shares;
    const capGain = (currentPrice - buyPrice) * shares;
    const totalReturn = incomeT + capGain;
    const totalReturnPct = buyPrice > 0 ? ((currentPrice - buyPrice + trailing) / buyPrice) * 100 : 0;
    const upCG = capGain >= 0, upTR = totalReturn >= 0;
    (document.getElementById('dyTrailingYield') as HTMLElement).textContent = trailingYield.toFixed(2) + '%';
    (document.getElementById('dyForwardYield') as HTMLElement).textContent = forwardYield.toFixed(2) + '%';
    (document.getElementById('dyYOC') as HTMLElement).textContent = yoc.toFixed(2) + '%';
    (document.getElementById('dyIncomeTrailing') as HTMLElement).textContent = fmt(incomeT);
    (document.getElementById('dyIncomeForward') as HTMLElement).textContent = fmt(incomeF);
    const cgEl = document.getElementById('dyCapGain')!;
    cgEl.textContent = (upCG ? '+' : '') + fmt(capGain);
    cgEl.className = `font-semibold ${upCG ? 'text-green-400' : 'text-red-400'}`;
    const trEl = document.getElementById('dyTotalReturn')!;
    trEl.textContent = (upTR ? '+' : '') + fmt(totalReturn) + ` (${totalReturnPct.toFixed(2)}%)`;
    trEl.className = `font-bold text-base ${upTR ? 'text-teal-400' : 'text-red-400'}`;
    document.getElementById('dyResult')?.classList.remove('hidden');
  });

  // DCA calculator
  document.getElementById('calcDcaBtn')?.addEventListener('click', () => {
    const monthly = parseFloat((document.getElementById('dcaMonthly') as HTMLInputElement).value) || 0;
    const annualReturn = parseFloat((document.getElementById('dcaReturn') as HTMLInputElement).value) || 0;
    const years = parseFloat((document.getElementById('dcaYears') as HTMLInputElement).value) || 0;
    const months = years * 12;
    const r = annualReturn / 100 / 12;
    const fv = r > 0 ? monthly * ((Math.pow(1 + r, months) - 1) / r) : monthly * months;
    const totalInvest = monthly * months;
    const profit = fv - totalInvest;
    (document.getElementById('dcaTotalInvest') as HTMLElement).textContent = fmt(totalInvest);
    (document.getElementById('dcaProfit') as HTMLElement).textContent = fmt(profit);
    (document.getElementById('dcaFinal') as HTMLElement).textContent = fmt(fv);
    document.getElementById('dcaResult')?.classList.remove('hidden');
  });

  // ── FIRE Calculator ─────────────────────────────────────────────────────────
  document.getElementById('calcFireBtn')?.addEventListener('click', () => {
    const expenses = parseFloat((document.getElementById('fireExpenses') as HTMLInputElement).value) || 0;
    const current = parseFloat((document.getElementById('fireCurrent') as HTMLInputElement).value) || 0;
    const savings = parseFloat((document.getElementById('fireSavings') as HTMLInputElement).value) || 0;
    const rPct = parseFloat((document.getElementById('fireReturn') as HTMLInputElement).value) || 0;
    const swrPct = parseFloat((document.getElementById('fireSWR') as HTMLInputElement).value) || 0;

    const r = rPct / 100;
    const swr = swrPct / 100;

    const fireNumber = swr > 0 ? expenses / swr : 0;
    
    let years = 0;
    if (current >= fireNumber) {
      years = 0;
    } else if (r === 0) {
      years = savings > 0 ? (fireNumber - current) / savings : Infinity;
    } else {
      const PMT_over_r = savings / r;
      const fv_term = fireNumber + PMT_over_r;
      const pv_term = current + PMT_over_r;
      if (pv_term <= 0 || fv_term < 0) {
        years = Infinity;
      } else {
        years = Math.log(fv_term / pv_term) / Math.log(1 + r);
      }
    }

    const fmtRp = (v: number) => 'Rp ' + Math.round(v).toLocaleString('id-ID');

    (document.getElementById('fireNumber') as HTMLElement).textContent = fmtRp(fireNumber);
    
    const yearsEl = document.getElementById('fireYears') as HTMLElement;
    const dateEl = document.getElementById('fireDate') as HTMLElement;
    
    if (years === 0) {
      yearsEl.textContent = 'Sudah Tercapai!';
      dateEl.textContent = 'Sekarang';
    } else if (!isFinite(years)) {
      yearsEl.textContent = 'Tidak akan tercapai';
      dateEl.textContent = '—';
    } else {
      const y = Math.floor(years);
      const m = Math.round((years - y) * 12);
      let yText = '';
      if (y > 0) yText += `${y} tahun `;
      if (m > 0) yText += `${m} bulan`;
      yearsEl.textContent = yText.trim() || '< 1 bulan';

      const d = new Date();
      d.setMonth(d.getMonth() + Math.round(years * 12));
      const monthsStr = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei', 'Jun', 'Jul', 'Agt', 'Sep', 'Okt', 'Nov', 'Des'];
      dateEl.textContent = `${monthsStr[d.getMonth()]} ${d.getFullYear()}`;
    }

    document.getElementById('fireResult')?.classList.remove('hidden');
  });
</script>
