---
import Layout from '../layouts/Layout.astro';
import TickerBar from '../components/TickerBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Stock Insight & Kalkulator Investasi — Regular Investor">
  <TickerBar />
  <Header />

  <main class="max-w-7xl mx-auto px-4 py-10">
    <div class="mb-8">
      <h1 class="text-2xl font-black text-white mb-2">Stock Insight & <span class="gradient-text">Kalkulator Investasi</span></h1>
      <p class="text-slate-400 text-sm">Hitung potensi return investasi Anda dengan tools analitis kami</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Dividend Calculator -->
      <div class="bg-[#151f2e] border border-[#1e2d3d] rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-green-500/15 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-base font-bold text-white">Kalkulator Dividen</h2>
            <p class="text-xs text-slate-500">Hitung yield dan pendapatan dividen tahunan</p>
          </div>
        </div>

        <div class="space-y-4" id="divCalc">
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Harga Beli per Lembar (Rp)</label>
            <input id="divPrice" type="number" placeholder="Contoh: 9850" value="9850"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-green-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Jumlah Lembar Saham</label>
            <input id="divShares" type="number" placeholder="Contoh: 1000" value="1000"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-green-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Dividen per Lembar (Rp)</label>
            <input id="divAmount" type="number" placeholder="Contoh: 200" value="200"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-green-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <button id="calcDivBtn" class="w-full bg-green-500 hover:bg-green-400 text-black font-bold py-3 rounded-xl transition-all text-sm">
            Hitung Dividen
          </button>
          <div id="divResult" class="hidden bg-[#0b1120] border border-green-500/20 rounded-xl p-4 space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Total Investasi</span>
              <span class="font-semibold text-white" id="divTotalInvest"></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Total Dividen Tahunan</span>
              <span class="font-semibold text-green-400" id="divTotalDiv"></span>
            </div>
            <div class="flex justify-between text-sm border-t border-[#1e2d3d] pt-2">
              <span class="text-slate-400">Dividend Yield</span>
              <span class="font-bold text-green-400 text-base" id="divYield"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- DCA Calculator -->
      <div class="bg-[#151f2e] border border-[#1e2d3d] rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-blue-500/15 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
          <div>
            <h2 class="text-base font-bold text-white">Kalkulator DCA</h2>
            <p class="text-xs text-slate-500">Dollar Cost Averaging — investasi rutin bulanan</p>
          </div>
        </div>

        <div class="space-y-4">
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Investasi Bulanan (Rp)</label>
            <input id="dcaMonthly" type="number" placeholder="Contoh: 1000000" value="1000000"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-blue-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Return Tahunan Estimasi (%)</label>
            <input id="dcaReturn" type="number" placeholder="Contoh: 12" value="12"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-blue-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Jangka Waktu (Tahun)</label>
            <input id="dcaYears" type="number" placeholder="Contoh: 10" value="10"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-blue-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <button id="calcDcaBtn" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl transition-all text-sm">
            Hitung DCA
          </button>
          <div id="dcaResult" class="hidden bg-[#0b1120] border border-blue-500/20 rounded-xl p-4 space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Total Investasi</span>
              <span class="font-semibold text-white" id="dcaTotalInvest"></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Total Keuntungan</span>
              <span class="font-semibold text-green-400" id="dcaProfit"></span>
            </div>
            <div class="flex justify-between text-sm border-t border-[#1e2d3d] pt-2">
              <span class="text-slate-400">Nilai Akhir Portofolio</span>
              <span class="font-bold text-blue-400 text-base" id="dcaFinal"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- CAGR / Compounding Calculator -->
      <div class="bg-[#151f2e] border border-[#1e2d3d] rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-amber-500/15 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-base font-bold text-white">Kalkulator CAGR & Compounding</h2>
            <p class="text-xs text-slate-500">Hitung pertumbuhan majemuk & laju pertumbuhan tahunan</p>
          </div>
        </div>

        <!-- Mode tabs -->
        <div class="flex gap-1 bg-[#0b1120] p-1 rounded-xl mb-5">
          <button id="cagrTabCompound" onclick="switchCAGRTab('compound')"
            class="flex-1 text-xs font-semibold py-2 rounded-lg transition-all bg-amber-500/15 text-amber-400 border border-amber-500/30">
            Compounding
          </button>
          <button id="cagrTabCAGR" onclick="switchCAGRTab('cagr')"
            class="flex-1 text-xs font-semibold py-2 rounded-lg transition-all text-slate-500 hover:text-slate-300">
            Hitung CAGR
          </button>
        </div>

        <!-- Compounding mode -->
        <div id="compoundMode" class="space-y-4">
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Modal Awal (Rp)</label>
            <input id="cpPrincipal" type="number" placeholder="Contoh: 10000000" value="10000000"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-amber-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Return Tahunan (%)</label>
            <input id="cpRate" type="number" placeholder="Contoh: 12" value="12"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-amber-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Jangka Waktu (Tahun)</label>
            <input id="cpYears" type="number" placeholder="Contoh: 10" value="10"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-amber-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Frekuensi Bunga</label>
            <select id="cpFreq"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-amber-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors">
              <option value="1">Tahunan (1×)</option>
              <option value="2">Semesteran (2×)</option>
              <option value="4">Kuartalan (4×)</option>
              <option value="12" selected>Bulanan (12×)</option>
              <option value="365">Harian (365×)</option>
            </select>
          </div>
          <button id="calcCpBtn" class="w-full bg-amber-500 hover:bg-amber-400 text-black font-bold py-3 rounded-xl transition-all text-sm">
            Hitung Compounding
          </button>
          <div id="cpResult" class="hidden bg-[#0b1120] border border-amber-500/20 rounded-xl p-4 space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Modal Awal</span>
              <span class="font-semibold text-white" id="cpPrincipalOut"></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Total Bunga / Gain</span>
              <span class="font-semibold text-amber-400" id="cpGain"></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Multiplier</span>
              <span class="font-semibold text-amber-300" id="cpMultiplier"></span>
            </div>
            <div class="flex justify-between text-sm border-t border-[#1e2d3d] pt-2">
              <span class="text-slate-400">Nilai Akhir</span>
              <span class="font-bold text-amber-400 text-base" id="cpFinal"></span>
            </div>
            <!-- Year-by-year breakdown toggle -->
            <button id="cpToggleBreakdown" class="w-full text-xs text-amber-400/70 hover:text-amber-400 mt-1 transition-colors">
              Lihat proyeksi per tahun ▾
            </button>
            <div id="cpBreakdown" class="hidden mt-2 space-y-1 max-h-48 overflow-y-auto pr-1"></div>
          </div>
        </div>

        <!-- CAGR mode -->
        <div id="cagrMode" class="hidden space-y-4">
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Nilai Awal (Rp)</label>
            <input id="cagrStart" type="number" placeholder="Contoh: 10000000" value="10000000"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-amber-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Nilai Akhir (Rp)</label>
            <input id="cagrEnd" type="number" placeholder="Contoh: 25000000" value="25000000"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-amber-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Jangka Waktu (Tahun)</label>
            <input id="cagrYears" type="number" placeholder="Contoh: 5" value="5"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-amber-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <button id="calcCAGRBtn" class="w-full bg-amber-500 hover:bg-amber-400 text-black font-bold py-3 rounded-xl transition-all text-sm">
            Hitung CAGR
          </button>
          <div id="cagrResult" class="hidden bg-[#0b1120] border border-amber-500/20 rounded-xl p-4 space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Total Return</span>
              <span class="font-semibold text-amber-400" id="cagrTotalReturn"></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Return Absolut</span>
              <span class="font-semibold text-white" id="cagrAbsReturn"></span>
            </div>
            <div class="flex justify-between text-sm border-t border-[#1e2d3d] pt-2">
              <span class="text-slate-400">CAGR</span>
              <span class="font-bold text-amber-400 text-xl" id="cagrRate"></span>
            </div>
            <p class="text-[11px] text-slate-500 pt-1">Tingkat pertumbuhan majemuk tahunan rata-rata selama periode investasi</p>
          </div>
        </div>
      </div>

      <!-- Dividend Yield Calculator -->
      <div class="bg-[#151f2e] border border-[#1e2d3d] rounded-2xl p-6">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 bg-teal-500/15 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-teal-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a2 2 0 012-2z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-base font-bold text-white">Kalkulator Dividend Yield</h2>
            <p class="text-xs text-slate-500">Forward yield, trailing yield & yield on cost</p>
          </div>
        </div>

        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="text-xs font-semibold text-slate-400 block mb-1.5">Harga Saat Ini (Rp)</label>
              <input id="dyCurrentPrice" type="number" placeholder="Contoh: 9850" value="9850"
                class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-teal-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
            </div>
            <div>
              <label class="text-xs font-semibold text-slate-400 block mb-1.5">Harga Beli (Rp)</label>
              <input id="dyBuyPrice" type="number" placeholder="Contoh: 7500" value="7500"
                class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-teal-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="text-xs font-semibold text-slate-400 block mb-1.5">Dividen Tahun Lalu (Rp)</label>
              <input id="dyTrailing" type="number" placeholder="Contoh: 340" value="340"
                class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-teal-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
            </div>
            <div>
              <label class="text-xs font-semibold text-slate-400 block mb-1.5">Estimasi Dividen Depan (Rp)</label>
              <input id="dyForward" type="number" placeholder="Contoh: 380" value="380"
                class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-teal-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
            </div>
          </div>
          <div>
            <label class="text-xs font-semibold text-slate-400 block mb-1.5">Jumlah Lembar Dimiliki</label>
            <input id="dyShares" type="number" placeholder="Contoh: 1000" value="1000"
              class="w-full bg-[#0b1120] border border-[#1e2d3d] focus:border-teal-500/50 rounded-xl px-4 py-3 text-sm text-slate-200 outline-none transition-colors"/>
          </div>
          <button id="calcDyBtn" class="w-full bg-teal-500 hover:bg-teal-400 text-black font-bold py-3 rounded-xl transition-all text-sm">
            Hitung Dividend Yield
          </button>
          <div id="dyResult" class="hidden bg-[#0b1120] border border-teal-500/20 rounded-xl p-4 space-y-3">
            <!-- Yield cards row -->
            <div class="grid grid-cols-3 gap-2 pb-3 border-b border-[#1e2d3d]">
              <div class="text-center">
                <div class="text-[10px] text-slate-500 mb-1">Trailing Yield</div>
                <div class="text-lg font-black text-teal-400" id="dyTrailingYield"></div>
              </div>
              <div class="text-center">
                <div class="text-[10px] text-slate-500 mb-1">Forward Yield</div>
                <div class="text-lg font-black text-teal-300" id="dyForwardYield"></div>
              </div>
              <div class="text-center">
                <div class="text-[10px] text-slate-500 mb-1">Yield on Cost</div>
                <div class="text-lg font-black text-green-400" id="dyYOC"></div>
              </div>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Pendapatan Dividen (Trailing)</span>
              <span class="font-semibold text-white" id="dyIncomeTrailing"></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Pendapatan Dividen (Forward)</span>
              <span class="font-semibold text-teal-400" id="dyIncomeForward"></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-slate-400">Capital Gain / Loss</span>
              <span class="font-semibold" id="dyCapGain"></span>
            </div>
            <div class="flex justify-between text-sm border-t border-[#1e2d3d] pt-2">
              <span class="text-slate-400">Total Return (Trailing + CG)</span>
              <span class="font-bold text-base" id="dyTotalReturn"></span>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- Market data table -->
    <div class="mt-8 bg-[#151f2e] border border-[#1e2d3d] rounded-2xl overflow-hidden">
      <div class="flex items-center justify-between px-6 py-4 border-b border-[#1e2d3d]">
        <h2 class="text-base font-bold text-white">Data Pasar Hari Ini</h2>
        <span class="text-xs text-green-400 flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse inline-block"></span>
          Live Data
        </span>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[#1e2d3d] bg-[#0d1525]">
              <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Instrumen</th>
              <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Harga</th>
              <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Perubahan</th>
              <th class="text-right px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider hidden md:table-cell">Volume</th>
            </tr>
          </thead>
          <tbody>
            {[
              { name: "IHSG", price: "7,254.18", chg: "+1.24%", vol: "28.4B", up: true },
              { name: "BBCA", price: "9,850", chg: "+0.51%", vol: "182.3M", up: true },
              { name: "TLKM", price: "3,120", chg: "-0.64%", vol: "94.1M", up: false },
              { name: "ASII", price: "4,780", chg: "+1.08%", vol: "67.8M", up: true },
              { name: "BMRI", price: "6,250", chg: "+0.80%", vol: "143.2M", up: true },
              { name: "GOTO", price: "74", chg: "-2.63%", vol: "1.2B", up: false },
              { name: "ANTM", price: "1,680", chg: "+2.44%", vol: "312.5M", up: true },
              { name: "INCO", price: "3,890", chg: "-1.27%", vol: "45.6M", up: false },
            ].map((row, i) => (
              <tr class={`border-b border-[#1e2d3d] hover:bg-[#0d1525] transition-colors ${i % 2 === 0 ? '' : 'bg-[#0b1120]/30'}`}>
                <td class="px-6 py-3.5 font-semibold text-slate-200">{row.name}</td>
                <td class="px-6 py-3.5 text-right font-mono text-slate-300">{row.price}</td>
                <td class={`px-6 py-3.5 text-right font-semibold ${row.up ? 'text-green-400' : 'text-red-400'}`}>
                  {row.up ? '▲' : '▼'} {row.chg}
                </td>
                <td class="px-6 py-3.5 text-right text-slate-500 hidden md:table-cell">{row.vol}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  // Dividend calculator
  document.getElementById('calcDivBtn')?.addEventListener('click', () => {
    const price = parseFloat((document.getElementById('divPrice') as HTMLInputElement).value) || 0;
    const shares = parseFloat((document.getElementById('divShares') as HTMLInputElement).value) || 0;
    const divAmt = parseFloat((document.getElementById('divAmount') as HTMLInputElement).value) || 0;

    const totalInvest = price * shares;
    const totalDiv = divAmt * shares;
    const yield_ = totalInvest > 0 ? (totalDiv / totalInvest * 100) : 0;

    const fmt = (n: number) => 'Rp ' + n.toLocaleString('id-ID');

    (document.getElementById('divTotalInvest') as HTMLElement).textContent = fmt(totalInvest);
    (document.getElementById('divTotalDiv') as HTMLElement).textContent = fmt(totalDiv);
    (document.getElementById('divYield') as HTMLElement).textContent = yield_.toFixed(2) + '%';
    document.getElementById('divResult')?.classList.remove('hidden');
  });

  // ── CAGR tab switcher ──────────────────────────────────────────────────────
  function switchCAGRTab(mode: string) {
    const compound = document.getElementById('compoundMode')!;
    const cagr = document.getElementById('cagrMode')!;
    const tabC = document.getElementById('cagrTabCompound')!;
    const tabR = document.getElementById('cagrTabCAGR')!;

    if (mode === 'compound') {
      compound.classList.remove('hidden');
      cagr.classList.add('hidden');
      tabC.className = 'flex-1 text-xs font-semibold py-2 rounded-lg transition-all bg-amber-500/15 text-amber-400 border border-amber-500/30';
      tabR.className = 'flex-1 text-xs font-semibold py-2 rounded-lg transition-all text-slate-500 hover:text-slate-300';
    } else {
      cagr.classList.remove('hidden');
      compound.classList.add('hidden');
      tabR.className = 'flex-1 text-xs font-semibold py-2 rounded-lg transition-all bg-amber-500/15 text-amber-400 border border-amber-500/30';
      tabC.className = 'flex-1 text-xs font-semibold py-2 rounded-lg transition-all text-slate-500 hover:text-slate-300';
    }
  }
  (window as any).switchCAGRTab = switchCAGRTab;

  // ── Compounding calculator ─────────────────────────────────────────────────
  document.getElementById('calcCpBtn')?.addEventListener('click', () => {
    const P = parseFloat((document.getElementById('cpPrincipal') as HTMLInputElement).value) || 0;
    const r = parseFloat((document.getElementById('cpRate') as HTMLInputElement).value) / 100 || 0;
    const t = parseFloat((document.getElementById('cpYears') as HTMLInputElement).value) || 0;
    const n = parseFloat((document.getElementById('cpFreq') as HTMLSelectElement).value) || 1;

    const FV = P * Math.pow(1 + r / n, n * t);
    const gain = FV - P;
    const multiplier = FV / P;

    const fmt = (v: number) => 'Rp ' + Math.round(v).toLocaleString('id-ID');

    (document.getElementById('cpPrincipalOut') as HTMLElement).textContent = fmt(P);
    (document.getElementById('cpGain') as HTMLElement).textContent = fmt(gain);
    (document.getElementById('cpMultiplier') as HTMLElement).textContent = multiplier.toFixed(2) + '×';
    (document.getElementById('cpFinal') as HTMLElement).textContent = fmt(FV);
    document.getElementById('cpResult')?.classList.remove('hidden');

    // Build yearly breakdown
    const bd = document.getElementById('cpBreakdown')!;
    bd.innerHTML = '';
    for (let y = 1; y <= t; y++) {
      const yv = P * Math.pow(1 + r / n, n * y);
      const row = document.createElement('div');
      row.className = 'flex justify-between text-xs py-1 border-b border-[#1e2d3d]/50';
      row.innerHTML = `<span class="text-slate-500">Tahun ${y}</span><span class="text-amber-400 font-semibold">${fmt(yv)}</span>`;
      bd.appendChild(row);
    }
  });

  document.getElementById('cpToggleBreakdown')?.addEventListener('click', () => {
    const bd = document.getElementById('cpBreakdown')!;
    const btn = document.getElementById('cpToggleBreakdown')!;
    bd.classList.toggle('hidden');
    btn.textContent = bd.classList.contains('hidden') ? 'Lihat proyeksi per tahun ▾' : 'Sembunyikan proyeksi ▴';
  });

  // ── CAGR calculator ────────────────────────────────────────────────────────
  document.getElementById('calcCAGRBtn')?.addEventListener('click', () => {
    const start = parseFloat((document.getElementById('cagrStart') as HTMLInputElement).value) || 0;
    const end   = parseFloat((document.getElementById('cagrEnd')   as HTMLInputElement).value) || 0;
    const t     = parseFloat((document.getElementById('cagrYears') as HTMLInputElement).value) || 1;

    const cagr = (Math.pow(end / start, 1 / t) - 1) * 100;
    const totalReturn = ((end - start) / start) * 100;
    const absReturn = end - start;

    const fmt = (v: number) => 'Rp ' + Math.round(v).toLocaleString('id-ID');
    const up = absReturn >= 0;

    (document.getElementById('cagrTotalReturn') as HTMLElement).textContent = totalReturn.toFixed(2) + '%';
    (document.getElementById('cagrTotalReturn') as HTMLElement).className = `font-semibold ${up ? 'text-amber-400' : 'text-red-400'}`;
    (document.getElementById('cagrAbsReturn') as HTMLElement).textContent = (up ? '+' : '') + fmt(absReturn);
    (document.getElementById('cagrAbsReturn') as HTMLElement).className = `font-semibold ${up ? 'text-white' : 'text-red-400'}`;
    (document.getElementById('cagrRate') as HTMLElement).textContent = cagr.toFixed(2) + '%';
    (document.getElementById('cagrRate') as HTMLElement).className = `font-bold text-xl ${up ? 'text-amber-400' : 'text-red-400'}`;
    document.getElementById('cagrResult')?.classList.remove('hidden');
  });

  // ── Dividend Yield calculator ──────────────────────────────────────────────
  document.getElementById('calcDyBtn')?.addEventListener('click', () => {
    const currentPrice = parseFloat((document.getElementById('dyCurrentPrice') as HTMLInputElement).value) || 0;
    const buyPrice     = parseFloat((document.getElementById('dyBuyPrice')     as HTMLInputElement).value) || 0;
    const trailing     = parseFloat((document.getElementById('dyTrailing')     as HTMLInputElement).value) || 0;
    const forward      = parseFloat((document.getElementById('dyForward')      as HTMLInputElement).value) || 0;
    const shares       = parseFloat((document.getElementById('dyShares')       as HTMLInputElement).value) || 0;

    const trailingYield = currentPrice > 0 ? (trailing / currentPrice) * 100 : 0;
    const forwardYield  = currentPrice > 0 ? (forward  / currentPrice) * 100 : 0;
    const yoc           = buyPrice    > 0 ? (trailing  / buyPrice)    * 100 : 0;
    const incomeT       = trailing * shares;
    const incomeF       = forward  * shares;
    const capGain       = (currentPrice - buyPrice) * shares;
    const totalReturn   = incomeT + capGain;
    const totalReturnPct = buyPrice > 0 ? ((currentPrice - buyPrice + trailing) / buyPrice) * 100 : 0;

    const fmt = (v: number) => 'Rp ' + Math.round(v).toLocaleString('id-ID');
    const upCG = capGain >= 0;
    const upTR = totalReturn >= 0;

    (document.getElementById('dyTrailingYield') as HTMLElement).textContent = trailingYield.toFixed(2) + '%';
    (document.getElementById('dyForwardYield')  as HTMLElement).textContent = forwardYield.toFixed(2)  + '%';
    (document.getElementById('dyYOC')           as HTMLElement).textContent = yoc.toFixed(2)           + '%';
    (document.getElementById('dyIncomeTrailing') as HTMLElement).textContent = fmt(incomeT);
    (document.getElementById('dyIncomeForward')  as HTMLElement).textContent = fmt(incomeF);
    const cgEl = document.getElementById('dyCapGain')!;
    cgEl.textContent = (upCG ? '+' : '') + fmt(capGain);
    cgEl.className = `font-semibold ${upCG ? 'text-green-400' : 'text-red-400'}`;
    const trEl = document.getElementById('dyTotalReturn')!;
    trEl.textContent = (upTR ? '+' : '') + fmt(totalReturn) + ` (${totalReturnPct.toFixed(2)}%)`;
    trEl.className = `font-bold text-base ${upTR ? 'text-teal-400' : 'text-red-400'}`;
    document.getElementById('dyResult')?.classList.remove('hidden');
  });

  // ── DCA calculator ─────────────────────────────────────────────────────────
  document.getElementById('calcDcaBtn')?.addEventListener('click', () => {
    const monthly = parseFloat((document.getElementById('dcaMonthly') as HTMLInputElement).value) || 0;
    const annualReturn = parseFloat((document.getElementById('dcaReturn') as HTMLInputElement).value) || 0;
    const years = parseFloat((document.getElementById('dcaYears') as HTMLInputElement).value) || 0;

    const months = years * 12;
    const r = annualReturn / 100 / 12;
    const fv = r > 0 ? monthly * ((Math.pow(1 + r, months) - 1) / r) : monthly * months;
    const totalInvest = monthly * months;
    const profit = fv - totalInvest;

    const fmt = (n: number) => 'Rp ' + Math.round(n).toLocaleString('id-ID');

    (document.getElementById('dcaTotalInvest') as HTMLElement).textContent = fmt(totalInvest);
    (document.getElementById('dcaProfit') as HTMLElement).textContent = fmt(profit);
    (document.getElementById('dcaFinal') as HTMLElement).textContent = fmt(fv);
    document.getElementById('dcaResult')?.classList.remove('hidden');
  });
</script>
