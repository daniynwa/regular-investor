---
import { marketData } from '../data/articles.js';
---

<div class="bg-[#0d1525] border-b border-[#1e2d3d] overflow-hidden">
  <div class="flex items-center">
    <!-- Label -->
    <div class="flex-shrink-0 bg-green-500 text-black text-[11px] font-800 font-black tracking-widest uppercase px-3 py-2 z-10">
      LIVE
    </div>
    <!-- Scrolling ticker -->
    <div class="overflow-hidden flex-1 relative">
      <div class="flex ticker-scroll whitespace-nowrap">
        {[...marketData, ...marketData].map((item) => (
          <span class="inline-flex items-center gap-2 px-5 py-2 text-xs border-r border-[#1e2d3d]">
            <span class="font-semibold text-slate-300">{item.symbol}</span>
            <span class="text-slate-400">{item.value}</span>
            <span class={`font-semibold ${item.up ? 'text-green-400' : 'text-red-400'}`}>
              {item.up ? '▲' : '▼'} {item.change}
            </span>
          </span>
        ))}
      </div>
    </div>
    <!-- Date -->
    <div class="flex-shrink-0 hidden md:flex items-center gap-2 px-4 text-[11px] text-slate-500 border-l border-[#1e2d3d]">
      <span>22 Mei 2026</span>
    </div>
  </div>
</div>
