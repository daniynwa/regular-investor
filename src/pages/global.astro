---
import CategoryPage from '../components/CategoryPage.astro';
import { getArticlesByCategory } from '../lib/queries.js';
let articles = [];
try { articles = await getArticlesByCategory('Global'); }
catch { const s = await import('../data/articles.js'); articles = s.articles.filter((a: any) => a.category === 'Global'); }
---
<CategoryPage category="Global" label="Global"
  description="Geopolitik, kebijakan bank sentral dunia, perang dagang, dan tren ekonomi internasional."
  color="purple" icon="🌍" articles={articles} />
