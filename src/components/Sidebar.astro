---
interface Props {
  articles: any[];
}
const { articles = [] } = Astro.props;
const recent = articles.slice(0, 5);

const categoryColors = {
  Economics:  'bg-blue-500/15 text-blue-400 border-blue-500/25',
  Investment: 'bg-green-500/15 text-green-400 border-green-500/25',
  Business:   'bg-amber-500/15 text-amber-400 border-amber-500/25',
  Global:     'bg-purple-500/15 text-purple-400 border-purple-500/25',
  Technology: 'bg-teal-500/15 text-teal-400 border-teal-500/25',
  Nasional:   'bg-red-500/15 text-red-400 border-red-500/25',
};

import AdBanner from './AdBanner.astro';
---

<aside class="space-y-6">
  <!-- Sidebar Ad Banner -->
  <AdBanner position="sidebar" />

  <!-- Calculator CTA -->
  <div class="relative overflow-hidden bg-gradient-to-br from-[#0d2818] to-[#0b1120] border border-green-500/20 rounded-2xl p-5">
    <div class="absolute top-0 right-0 w-24 h-24 bg-green-500/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="relative">
      <div class="w-10 h-10 bg-green-500/15 rounded-xl flex items-center justify-center mb-3">
        <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 11h.01M12 11h.01M15 11h.01M4 5h16a1 1 0 011 1v12a1 1 0 01-1 1H4a1 1 0 01-1-1V6a1 1 0 011-1z"/>
        </svg>
      </div>
      <h3 class="text-sm font-bold text-white mb-1">Kalkulator Investasi</h3>
      <p class="text-xs text-slate-400 mb-4">Hitung potensi keuntungan dividen dan investasi Anda</p>
      <div class="flex flex-col gap-2">
        <a href="/compound-interest-calculator" class="flex items-center justify-center gap-1.5 bg-green-500 hover:bg-green-400 text-black text-xs font-bold px-3 py-2 rounded-lg transition-all">
          📈 Bunga Majemuk
        </a>
        <a href="/compound-interest-calculator" class="flex items-center justify-center gap-1.5 bg-[#151f2e] hover:bg-[#1a2840] border border-[#1e2d3d] text-slate-300 text-xs font-semibold px-3 py-2 rounded-lg transition-all">
          💰 Dividen & DCA
        </a>
      </div>
    </div>
  </div>

  <!-- Recent Posts -->
  <div class="bg-[#151f2e] border border-[#1e2d3d] rounded-2xl p-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-bold text-white">Berita Terbaru</h3>
      <a href="/economics" class="text-xs text-green-400 hover:text-green-300 transition-colors">Lihat semua →</a>
    </div>
    <div>
      {recent.map(article => {
        const catStyle = categoryColors[article.category] || 'bg-slate-500/15 text-slate-400 border-slate-500/25';
        const date = article.date instanceof Date ? article.date : new Date(article.date);
        return (
          <a href={`/${article.slug}`} class="group flex items-start gap-3 py-3 border-b border-[#1e2d3d] last:border-0 hover:bg-green-500/3 -mx-2 px-2 rounded-lg transition-all">
            <img
              src={article.image}
              alt={article.title}
              class="w-16 h-16 object-cover rounded-lg flex-shrink-0 opacity-90 group-hover:opacity-100 transition-opacity"
              loading="lazy"
              onerror="this.src='https://images.unsplash.com/photo-1611273426858-450d8e3c9fce?w=200&auto=format&fit=crop'"
            />
            <div class="flex-1 min-w-0">
              <span class={`tag-badge border ${catStyle} mb-1 inline-block`}>{article.category}</span>
              <h3 class="text-xs font-semibold text-slate-300 group-hover:text-green-400 transition-colors line-clamp-2 leading-snug">
                {article.title}
              </h3>
              <p class="text-[10px] text-slate-600 mt-1">
                {date.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
              </p>
            </div>
          </a>
        );
      })}
    </div>
  </div>

  <!-- Tags cloud -->
  <div class="bg-[#151f2e] border border-[#1e2d3d] rounded-2xl p-4">
    <h3 class="text-sm font-bold text-white mb-3">Topik Populer</h3>
    <div class="flex flex-wrap gap-2">
      {['Saham', 'Dividen', 'IHSG', 'Fed', 'Inflasi', 'Emas', 'Kripto', 'OJK', 'BI Rate', 'Komoditas', 'Mining', 'IDR'].map(tag => (
        <span class="text-xs bg-[#0b1120] hover:bg-green-500/10 border border-[#1e2d3d] hover:border-green-500/30 text-slate-400 hover:text-green-400 px-3 py-1.5 rounded-lg transition-all cursor-pointer">
          {tag}
        </span>
      ))}
    </div>
  </div>

  <!-- Newsletter mini -->
  <div class="bg-gradient-to-br from-[#0d1a35] to-[#0b1120] border border-blue-500/20 rounded-2xl p-5">
    <div class="w-10 h-10 bg-blue-500/15 rounded-xl flex items-center justify-center mb-3">
      <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>
    <h3 class="text-sm font-bold text-white mb-1">Newsletter Mingguan</h3>
    <p class="text-xs text-slate-400 mb-3">Ringkasan pasar dan analisis tiap minggu langsung ke inbox Anda</p>
    <div class="flex gap-2">
      <input type="email" placeholder="Email Anda"
        class="flex-1 bg-[#0b1120] border border-[#1e2d3d] focus:border-blue-500/50 rounded-lg px-3 py-2 text-xs text-slate-300 placeholder-slate-600 outline-none transition-colors"/>
      <button class="bg-blue-600 hover:bg-blue-500 text-white text-xs font-semibold px-3 py-2 rounded-lg transition-all flex-shrink-0">
        OK
      </button>
    </div>
  </div>
</aside>
