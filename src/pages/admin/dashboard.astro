---
import { verifySession } from '../../lib/auth.js';
import { getAllArticles, getArticlesByCategory, countArticles, countArticlesByCategory, getSocialLinks, getAdsSettings } from '../../lib/queries.js';

const session = await verifySession(Astro.request);
if (!session) return Astro.redirect('/admin');

const adminEmail = session.email || 'admin';
const adminName = session.name || 'Admin';

const categoryFilter = Astro.url.searchParams.get('cat');

let articles: any[] = [];
let total = 0;
let stats: any[] = [];
let socialLinks: any = {};
let adsSettings: any = {};
let currentUser: any = null;
let dbOk = false;

if (session.userId) {
  try {
    // Try to ensure phone column exists just in case
    try { await import('../../lib/db.js').then(m => m.query('ALTER TABLE admin_users ADD COLUMN phone VARCHAR(20) DEFAULT NULL')); } catch(e){}
    
    const rows = await import('../../lib/db.js').then(m => m.query('SELECT * FROM admin_users WHERE id = ?', [session.userId]));
    currentUser = rows[0];
  } catch(e) {}
}

try {
  [articles, total, stats, socialLinks, adsSettings] = await Promise.all([
    categoryFilter ? getArticlesByCategory(categoryFilter, { limit: 100 }) : getAllArticles({ limit: 100 }),
    countArticles(),
    countArticlesByCategory(),
    getSocialLinks(),
    getAdsSettings(),
  ]);
  dbOk = true;
} catch (e) {
  // DB not connected yet
  socialLinks = {
    social_facebook: '', social_twitter: '', social_instagram: '',
    social_youtube: '', social_telegram: '',
  };
  adsSettings = {
    ad_sidebar_image: '', ad_sidebar_link: '', ad_sidebar_active: '0',
    ad_top_image: '', ad_top_link: '', ad_top_active: '0',
  };
}

const categoryColors: Record<string, string> = {
  Economics: '#3b82f6', Investment: '#22c55e', Global: '#a855f7',
  Nasional: '#ef4444', Technology: '#14b8a6', Business: '#f59e0b',
};
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard Admin — Regular Investor</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0b1120; color: #e2e8f0; font-family: 'Inter', sans-serif; min-height: 100vh; }
    /* Layout */
    .layout { display: flex; min-height: 100vh; }
    /* Sidebar */
    .sidebar { width: 220px; background: #080f1c; border-right: 1px solid #1e2d3d; padding: 20px 0; flex-shrink: 0; position: fixed; top: 0; left: 0; height: 100vh; overflow-y: auto; display: flex; flex-direction: column; }
    .sidebar-logo { padding: 0 20px 24px; border-bottom: 1px solid #1e2d3d; }
    .logo-brand { font-size: 16px; font-weight: 900; }
    .logo-brand span { background: linear-gradient(135deg, #3b82f6, #22c55e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .logo-sub { font-size: 9px; color: #475569; letter-spacing: 0.12em; text-transform: uppercase; margin-top: 2px; }
    .nav-section { padding: 16px 20px 8px; font-size: 9px; font-weight: 700; color: #334155; letter-spacing: 0.12em; text-transform: uppercase; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 9px 20px; font-size: 13px; color: #64748b; text-decoration: none; transition: all 0.15s; cursor: pointer; border: none; background: none; width: 100%; text-align: left; font-family: inherit; }
    .nav-item:hover, .nav-item.active { color: #22c55e; background: rgba(34,197,94,0.07); }
    .nav-item.active { border-right: 2px solid #22c55e; }
    .sidebar-bottom { margin-top: auto; padding-top: 12px; border-top: 1px solid #1e2d3d; }
    .user-info { padding: 12px 20px; }
    .user-email { font-size: 11px; color: #64748b; word-break: break-all; }
    .user-name { font-size: 12px; color: #94a3b8; font-weight: 600; }
    /* Main */
    .main { margin-left: 220px; flex: 1; }
    .topbar { background: #0d1525; border-bottom: 1px solid #1e2d3d; padding: 14px 28px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 10; }
    .topbar-title { font-size: 16px; font-weight: 800; color: #fff; }
    .topbar-actions { display: flex; align-items: center; gap: 10px; }
    .btn { padding: 8px 16px; border-radius: 10px; font-size: 12px; font-weight: 700; border: none; cursor: pointer; text-decoration: none; transition: all 0.15s; display: inline-flex; align-items: center; gap: 6px; font-family: inherit; }
    .btn-primary { background: #22c55e; color: #000; }
    .btn-primary:hover { background: #4ade80; }
    .btn-secondary { background: #151f2e; color: #94a3b8; border: 1px solid #1e2d3d; }
    .btn-secondary:hover { color: #e2e8f0; }
    .btn-danger { background: rgba(239,68,68,0.1); color: #f87171; border: 1px solid rgba(239,68,68,0.2); }
    .btn-danger:hover { background: rgba(239,68,68,0.2); }
    .btn-warning { background: rgba(245,158,11,0.1); color: #fbbf24; border: 1px solid rgba(245,158,11,0.2); }
    .btn-warning:hover { background: rgba(245,158,11,0.2); }
    .btn-sm { padding: 5px 10px; font-size: 11px; border-radius: 7px; }
    .content { padding: 24px 28px; }
    /* Stats */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .stat-card { background: #151f2e; border: 1px solid #1e2d3d; border-radius: 14px; padding: 18px; }
    .stat-label { font-size: 10px; color: #64748b; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 700; margin-bottom: 6px; }
    .stat-value { font-size: 28px; font-weight: 900; }
    .stat-sub { font-size: 11px; color: #475569; margin-top: 4px; }
    /* Category pills */
    .cat-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
    .cat-pill { background: #151f2e; border: 1px solid #1e2d3d; border-radius: 8px; padding: 6px 12px; font-size: 11px; display: flex; align-items: center; gap: 6px; }
    .cat-dot { width: 8px; height: 8px; border-radius: 50%; }
    /* Table */
    .table-card { background: #151f2e; border: 1px solid #1e2d3d; border-radius: 16px; overflow: hidden; }
    .table-header { padding: 16px 20px; border-bottom: 1px solid #1e2d3d; display: flex; align-items: center; justify-content: space-between; }
    .table-header h2 { font-size: 14px; font-weight: 800; color: #fff; }
    table { width: 100%; border-collapse: collapse; font-size: 12px; }
    th { padding: 10px 16px; text-align: left; color: #475569; font-weight: 700; font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; background: #0d1525; border-bottom: 1px solid #1e2d3d; }
    td { padding: 12px 16px; border-bottom: 1px solid #1e2d3d; color: #94a3b8; vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(255,255,255,0.01); }
    .td-title { color: #e2e8f0; font-weight: 500; max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .badge { display: inline-flex; padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; }
    .featured-badge { background: rgba(34,197,94,0.12); color: #22c55e; border: 1px solid rgba(34,197,94,0.2); }
    .status-active { background: rgba(34,197,94,0.12); color: #22c55e; border: 1px solid rgba(34,197,94,0.2); }
    .status-pending { background: rgba(245,158,11,0.12); color: #fbbf24; border: 1px solid rgba(245,158,11,0.2); }
    .status-disabled { background: rgba(239,68,68,0.12); color: #f87171; border: 1px solid rgba(239,68,68,0.2); }
    .actions { display: flex; gap: 6px; }
    .db-warning { background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.2); border-radius: 12px; padding: 14px 18px; margin-bottom: 20px; font-size: 12px; color: #fbbf24; }
    .search-bar { padding: 8px 14px; background: #0b1120; border: 1px solid #1e2d3d; border-radius: 10px; color: #e2e8f0; font-size: 12px; width: 220px; outline: none; font-family: inherit; }
    .search-bar:focus { border-color: rgba(34,197,94,0.4); }
    /* Panels */
    .panel { display: none; }
    .panel.active { display: block; }
    /* Settings form */
    .settings-card { background: #151f2e; border: 1px solid #1e2d3d; border-radius: 16px; padding: 24px; margin-bottom: 20px; }
    .settings-card h3 { font-size: 14px; font-weight: 800; color: #fff; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 11px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
    .form-group input { width: 100%; background: #0b1120; border: 1px solid #1e2d3d; border-radius: 10px; padding: 10px 14px; font-size: 13px; color: #e2e8f0; outline: none; transition: border-color 0.15s; font-family: inherit; }
    .form-group input:focus { border-color: rgba(34,197,94,0.4); }
    .form-group .hint { font-size: 10px; color: #475569; margin-top: 4px; }
    .save-msg { font-size: 12px; margin-top: 12px; display: none; }
    .save-msg.show { display: block; }
    .save-msg.success { color: #4ade80; }
    .save-msg.error { color: #f87171; }
  </style>
</head>
<body>
<div class="layout">
  <!-- Sidebar -->
  <nav class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-brand"><span>Regular</span> Investor</div>
      <div class="logo-sub">Admin Panel</div>
    </div>
    <div class="nav-section">Menu</div>
    <button class="nav-item active" data-panel="dashboard">📊 Dashboard</button>
    <a href="/admin/articles/new" class="nav-item">✏️ Artikel Baru</a>
    <div class="nav-section">Pengaturan</div>
    <button class="nav-item" data-panel="profile">👤 Profil Saya</button>
    <button class="nav-item" data-panel="ads">📢 Manajemen Iklan</button>
    <button class="nav-item" data-panel="social">🔗 Social Media</button>
    <button class="nav-item" data-panel="users">👥 Kelola Admin</button>
    <div class="nav-section">Konten</div>
    <a href="/admin/dashboard?cat=Economics"  class="nav-item">🏦 Economics</a>
    <a href="/admin/dashboard?cat=Investment" class="nav-item">💰 Investment</a>
    <a href="/admin/dashboard?cat=Nasional"   class="nav-item">🇮🇩 Nasional</a>
    <a href="/admin/dashboard?cat=Global"     class="nav-item">🌍 Global</a>
    <a href="/admin/dashboard?cat=Technology" class="nav-item">💻 Technology</a>

    <div class="sidebar-bottom">
      <div class="user-info">
        <div class="user-name">{adminName}</div>
        <div class="user-email">{adminEmail}</div>
      </div>
      <div class="nav-section">Lainnya</div>
      <a href="/" target="_blank" class="nav-item">🔗 Lihat Situs</a>
      <button class="nav-item" id="logoutBtn">🚪 Keluar</button>
    </div>
  </nav>

  <!-- Main content -->
  <div class="main">
    <div class="topbar">
      <span class="topbar-title" id="panelTitle">Dashboard</span>
      <div class="topbar-actions">
        <input class="search-bar" type="search" id="searchInput" placeholder="🔍 Cari artikel..."/>
        <a href="/admin/articles/new" class="btn btn-primary">+ Artikel Baru</a>
      </div>
    </div>

    <div class="content">
      {!dbOk && (
        <div class="db-warning">
          ⚠️ <strong>Database belum terhubung.</strong> Pastikan MySQL berjalan dan konfigurasi <code>.env</code> sudah benar. Jalankan <code>database/schema.sql</code> dan <code>database/seed.sql</code>.
        </div>
      )}

      <!-- ═══ DASHBOARD PANEL ═══ -->
      <div class="panel active" id="panel-dashboard">
        <!-- Stats -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-label">Total Artikel</div>
            <div class="stat-value" style="color:#22c55e">{total}</div>
            <div class="stat-sub">Di semua kategori</div>
          </div>
          {stats.slice(0, 3).map((s: any) => (
            <div class="stat-card">
              <div class="stat-label">{s.category}</div>
              <div class="stat-value" style={`color:${categoryColors[s.category] || '#94a3b8'}`}>{s.total}</div>
              <div class="stat-sub">Artikel</div>
            </div>
          ))}
        </div>

        <!-- Category stats -->
        <div class="cat-grid">
          {stats.map((s: any) => (
            <div class="cat-pill">
              <div class="cat-dot" style={`background:${categoryColors[s.category] || '#94a3b8'}`}></div>
              <span style="color:#94a3b8">{s.category}</span>
              <strong style="color:#e2e8f0">{s.total}</strong>
            </div>
          ))}
        </div>

        <!-- Articles table -->
        <div class="table-card">
          <div class="table-header">
            <h2>{categoryFilter ? `Artikel Kategori: ${categoryFilter}` : 'Semua Artikel'}</h2>
            <span style="font-size:11px; color:#475569">{articles.length} ditampilkan</span>
          </div>
          <table id="articlesTable">
            <thead>
              <tr>
                <th>ID</th>
                <th>Judul</th>
                <th>Kategori</th>
                <th>Tanggal</th>
                <th>Featured</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              {articles.length === 0 && (
                <tr><td colspan="6" style="text-align:center; color:#475569; padding:40px">Belum ada artikel di database</td></tr>
              )}
              {articles.map((a: any) => {
                const date = a.date instanceof Date ? a.date : new Date(a.date);
                const color = categoryColors[a.category] || '#94a3b8';
                return (
                  <tr data-title={a.title.toLowerCase()} data-cat={a.category}>
                    <td style="color:#475569">{a.id}</td>
                    <td class="td-title">{a.title}</td>
                    <td>
                      <span class="badge" style={`background:${color}18; color:${color}; border:1px solid ${color}30`}>{a.category}</span>
                    </td>
                    <td>{date.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}</td>
                    <td>{a.featured ? <span class="badge featured-badge">Ya</span> : <span style="color:#334155">—</span>}</td>
                    <td>
                      <div class="actions">
                        <a href={`/admin/articles/${a.id}`} class="btn btn-secondary btn-sm">Edit</a>
                        <a href={`/${a.slug}`} target="_blank" class="btn btn-secondary btn-sm">↗</a>
                        <button class="btn btn-danger btn-sm delete-btn" data-id={a.id} data-title={a.title}>Hapus</button>
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

      <!-- ═══ PROFILE PANEL ═══ -->
      <div class="panel" id="panel-profile">
        <div class="settings-card">
          <h3>👤 Profil Saya</h3>
          <p style="font-size:12px; color:#64748b; margin-bottom:20px;">
            Perbarui informasi profil Anda.
          </p>
          <div class="form-group">
            <label>Nama Lengkap</label>
            <input type="text" id="profileName" value={currentUser?.name || ''} placeholder="John Doe"/>
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" id="profileEmail" value={currentUser?.email || ''} placeholder="admin@gmail.com"/>
          </div>
          <div class="form-group">
            <label>Nomor Telepon</label>
            <input type="tel" id="profilePhone" value={currentUser?.phone || ''} placeholder="081234567890"/>
          </div>
          <button class="btn btn-primary" id="saveProfileBtn">💾 Simpan Profil</button>
          <div class="save-msg" id="profileMsg"></div>
        </div>
      </div>

      <!-- ═══ ADS PANEL ═══ -->
      <div class="panel" id="panel-ads">
        <div class="settings-card">
          <h3>📢 Manajemen Iklan (Banner Ads)</h3>
          <p style="font-size:12px; color:#64748b; margin-bottom:20px;">
            Atur gambar dan tautan iklan yang muncul di website. Gunakan URL gambar untuk banner (gambar akan menyesuaikan ukuran frame secara otomatis).
          </p>
          
          <h4 style="font-size:12px; font-weight:700; color:#fff; margin:24px 0 12px; border-bottom:1px solid #1e2d3d; padding-bottom:8px;">1. Sidebar Banner (Kotak Kanan)</h4>
          <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px;">
            <label style="font-size:11px; font-weight:700; color:#94a3b8; text-transform:uppercase;">Status Aktif:</label>
            <label style="position:relative; display:inline-block; width:40px; height:22px;">
              <input type="checkbox" id="adSidebarActive" style="opacity:0; width:0; height:0;" {adsSettings.ad_sidebar_active === '1' ? 'checked' : ''}/>
              <span style="position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background-color:#1e2d3d; transition:.4s; border-radius:34px;" class="slider"></span>
              <style>
                #adSidebarActive:checked + .slider { background-color: #22c55e; }
                .slider:before { position:absolute; content:""; height:16px; width:16px; left:3px; bottom:3px; background-color:white; transition:.4s; border-radius:50%; }
                #adSidebarActive:checked + .slider:before { transform: translateX(18px); }
              </style>
            </label>
          </div>
          <div class="form-group">
            <label>Gambar Banner URL</label>
            <input type="url" id="adSidebarImage" value={adsSettings.ad_sidebar_image || ''} placeholder="https://example.com/banner-300x250.jpg"/>
            <div class="hint">Rekomendasi ukuran: 300x250px atau 300x600px</div>
          </div>
          <div class="form-group">
            <label>Link Tujuan (Target URL)</label>
            <input type="url" id="adSidebarLink" value={adsSettings.ad_sidebar_link || ''} placeholder="https://dompetx.com"/>
          </div>

          <h4 style="font-size:12px; font-weight:700; color:#fff; margin:32px 0 12px; border-bottom:1px solid #1e2d3d; padding-bottom:8px;">2. Top Banner (Bawah Header)</h4>
          <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px;">
            <label style="font-size:11px; font-weight:700; color:#94a3b8; text-transform:uppercase;">Status Aktif:</label>
            <label style="position:relative; display:inline-block; width:40px; height:22px;">
              <input type="checkbox" id="adTopActive" style="opacity:0; width:0; height:0;" {adsSettings.ad_top_active === '1' ? 'checked' : ''}/>
              <span style="position:absolute; cursor:pointer; top:0; left:0; right:0; bottom:0; background-color:#1e2d3d; transition:.4s; border-radius:34px;" class="slider"></span>
              <style>
                #adTopActive:checked + .slider { background-color: #22c55e; }
                #adTopActive:checked + .slider:before { transform: translateX(18px); }
              </style>
            </label>
          </div>
          <div class="form-group">
            <label>Gambar Banner URL</label>
            <input type="url" id="adTopImage" value={adsSettings.ad_top_image || ''} placeholder="https://example.com/banner-728x90.jpg"/>
            <div class="hint">Rekomendasi ukuran: 728x90px (Horizontal)</div>
          </div>
          <div class="form-group">
            <label>Link Tujuan (Target URL)</label>
            <input type="url" id="adTopLink" value={adsSettings.ad_top_link || ''} placeholder="https://dompetx.com/promo"/>
          </div>

          <button class="btn btn-primary" id="saveAdsBtn" style="margin-top:16px;">💾 Simpan Pengaturan Iklan</button>
          <div class="save-msg" id="adsMsg"></div>
        </div>
      </div>

      <!-- ═══ SOCIAL MEDIA PANEL ═══ -->
      <div class="panel" id="panel-social">
        <div class="settings-card">
          <h3>🔗 Link Social Media</h3>
          <p style="font-size:12px; color:#64748b; margin-bottom:20px;">
            Update link social media yang ditampilkan di footer website. Kosongkan jika tidak ingin menampilkan icon tersebut.
          </p>
          <div class="form-group">
            <label>Facebook URL</label>
            <input type="url" id="socialFacebook" value={socialLinks.social_facebook || ''} placeholder="https://facebook.com/regularinvestor"/>
            <div class="hint">Contoh: https://facebook.com/regularinvestor</div>
          </div>
          <div class="form-group">
            <label>Twitter / X URL</label>
            <input type="url" id="socialTwitter" value={socialLinks.social_twitter || ''} placeholder="https://x.com/regularinvestor"/>
            <div class="hint">Contoh: https://x.com/regularinvestor</div>
          </div>
          <div class="form-group">
            <label>Instagram URL</label>
            <input type="url" id="socialInstagram" value={socialLinks.social_instagram || ''} placeholder="https://instagram.com/regularinvestor"/>
          </div>
          <div class="form-group">
            <label>YouTube URL</label>
            <input type="url" id="socialYoutube" value={socialLinks.social_youtube || ''} placeholder="https://youtube.com/@regularinvestor"/>
          </div>
          <div class="form-group">
            <label>Telegram URL</label>
            <input type="url" id="socialTelegram" value={socialLinks.social_telegram || ''} placeholder="https://t.me/regularinvestor"/>
          </div>
          <button class="btn btn-primary" id="saveSocialBtn">💾 Simpan Social Media</button>
          <div class="save-msg" id="socialMsg"></div>
        </div>
      </div>

      <!-- ═══ ADMIN USERS PANEL ═══ -->
      <div class="panel" id="panel-users">
        <div class="settings-card">
          <h3>👥 Kelola Admin</h3>
          <p style="font-size:12px; color:#64748b; margin-bottom:20px;">
            Setujui, tolak, atau nonaktifkan akun admin. Admin baru yang mendaftar akan berstatus <span class="badge status-pending">pending</span> hingga disetujui.
          </p>
          <div id="usersLoading" style="text-align:center; color:#475569; padding:20px;">Memuat data admin...</div>
          <div class="table-card" id="usersTableCard" style="display:none;">
            <table>
              <thead>
                <tr>
                  <th>Nama</th>
                  <th>Email</th>
                  <th>Status</th>
                  <th>Terdaftar</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody id="usersTableBody"></tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  // ── Panel switching ─────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-panel]').forEach(btn => {
    btn.addEventListener('click', () => {
      // Deactivate all nav items with data-panel
      document.querySelectorAll<HTMLElement>('[data-panel]').forEach(b => b.classList.remove('active'));
      // Hide all panels
      document.querySelectorAll<HTMLElement>('.panel').forEach(p => p.classList.remove('active'));
      // Activate clicked
      btn.classList.add('active');
      const panelId = 'panel-' + btn.dataset.panel;
      document.getElementById(panelId)?.classList.add('active');
      // Update title
      const titles: Record<string, string> = {
        dashboard: 'Dashboard',
        profile: 'Profil Saya',
        ads: 'Manajemen Iklan',
        social: 'Social Media Settings',
        users: 'Kelola Admin',
      };
      const titleEl = document.getElementById('panelTitle');
      if (titleEl) titleEl.textContent = titles[btn.dataset.panel!] || 'Dashboard';
      // Load users if needed
      if (btn.dataset.panel === 'users') loadUsers();
    });
  });

  // ── Logout ──────────────────────────────────────────────────────────────────
  document.getElementById('logoutBtn')?.addEventListener('click', async (e) => {
    e.preventDefault();
    try {
      await fetch('/api/admin/logout', { method: 'POST', credentials: 'same-origin' });
    } catch {}
    window.location.href = '/admin';
  });

  // ── Search filter ───────────────────────────────────────────────────────────
  document.getElementById('searchInput')?.addEventListener('input', (e) => {
    const q = (e.target as HTMLInputElement).value.toLowerCase();
    document.querySelectorAll<HTMLTableRowElement>('#articlesTable tbody tr[data-title]').forEach(row => {
      const match = row.dataset.title?.includes(q) || row.dataset.cat?.toLowerCase().includes(q);
      row.style.display = match ? '' : 'none';
    });
  });

  // ── Delete article ──────────────────────────────────────────────────────────
  document.querySelectorAll('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = (btn as HTMLElement).dataset.id;
      const title = (btn as HTMLElement).dataset.title;
      if (!confirm(`Hapus artikel:\n"${title}"\n\nTindakan ini tidak bisa dibatalkan.`)) return;
      const res = await fetch(`/api/admin/articles/${id}`, { method: 'DELETE', credentials: 'same-origin' });
      if (res.ok) {
        btn.closest('tr')?.remove();
      } else {
        alert('Gagal menghapus artikel.');
      }
    });
  });

  // ── Save social media ──────────────────────────────────────────────────────
  document.getElementById('saveSocialBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('saveSocialBtn') as HTMLButtonElement;
    const msg = document.getElementById('socialMsg')!;
    btn.disabled = true;
    btn.textContent = 'Menyimpan...';
    msg.classList.remove('show', 'success', 'error');

    const data = {
      social_facebook: (document.getElementById('socialFacebook') as HTMLInputElement).value,
      social_twitter: (document.getElementById('socialTwitter') as HTMLInputElement).value,
      social_instagram: (document.getElementById('socialInstagram') as HTMLInputElement).value,
      social_youtube: (document.getElementById('socialYoutube') as HTMLInputElement).value,
      social_telegram: (document.getElementById('socialTelegram') as HTMLInputElement).value,
    };

    try {
      const res = await fetch('/api/admin/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        credentials: 'same-origin',
      });
      if (res.ok) {
        msg.textContent = '✓ Social media berhasil disimpan!';
        msg.classList.add('show', 'success');
      } else {
        msg.textContent = '✗ Gagal menyimpan. Pastikan database terhubung.';
        msg.classList.add('show', 'error');
      }
    } catch {
      msg.textContent = '✗ Gagal terhubung ke server.';
      msg.classList.add('show', 'error');
    }
    btn.disabled = false;
    btn.textContent = '💾 Simpan Social Media';
  });

  // ── Save Ads ─────────────────────────────────────────────────────────────────
  document.getElementById('saveAdsBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('saveAdsBtn') as HTMLButtonElement;
    const msg = document.getElementById('adsMsg')!;
    btn.disabled = true;
    btn.textContent = 'Menyimpan...';
    msg.classList.remove('show', 'success', 'error');

    const data = {
      ad_sidebar_image: (document.getElementById('adSidebarImage') as HTMLInputElement).value,
      ad_sidebar_link: (document.getElementById('adSidebarLink') as HTMLInputElement).value,
      ad_sidebar_active: (document.getElementById('adSidebarActive') as HTMLInputElement).checked ? '1' : '0',
      ad_top_image: (document.getElementById('adTopImage') as HTMLInputElement).value,
      ad_top_link: (document.getElementById('adTopLink') as HTMLInputElement).value,
      ad_top_active: (document.getElementById('adTopActive') as HTMLInputElement).checked ? '1' : '0',
    };

    try {
      const res = await fetch('/api/admin/ads', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        credentials: 'same-origin',
      });
      if (res.ok) {
        msg.textContent = '✓ Pengaturan iklan berhasil disimpan!';
        msg.classList.add('show', 'success');
      } else {
        msg.textContent = '✗ Gagal menyimpan pengaturan iklan.';
        msg.classList.add('show', 'error');
      }
    } catch {
      msg.textContent = '✗ Gagal terhubung ke server.';
      msg.classList.add('show', 'error');
    }
    btn.disabled = false;
    btn.textContent = '💾 Simpan Pengaturan Iklan';
  });

  // ── Save Profile ──────────────────────────────────────────────────────────
  document.getElementById('saveProfileBtn')?.addEventListener('click', async () => {
    const btn = document.getElementById('saveProfileBtn') as HTMLButtonElement;
    const msg = document.getElementById('profileMsg')!;
    btn.disabled = true;
    btn.textContent = 'Menyimpan...';
    msg.classList.remove('show', 'success', 'error');

    const data = {
      name: (document.getElementById('profileName') as HTMLInputElement).value,
      email: (document.getElementById('profileEmail') as HTMLInputElement).value,
      phone: (document.getElementById('profilePhone') as HTMLInputElement).value,
    };

    try {
      const res = await fetch('/api/admin/profile', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        credentials: 'same-origin',
      });
      if (res.ok) {
        msg.textContent = '✓ Profil berhasil diperbarui!';
        msg.classList.add('show', 'success');
        // Update sidebar name/email if desired
        const nameEl = document.querySelector('.user-name');
        const emailEl = document.querySelector('.user-email');
        if (nameEl) nameEl.textContent = data.name || 'Admin';
        if (emailEl) emailEl.textContent = data.email;
      } else {
        const err = await res.json();
        msg.textContent = `✗ Gagal: ${err.error || 'Unknown error'}`;
        msg.classList.add('show', 'error');
      }
    } catch {
      msg.textContent = '✗ Gagal terhubung ke server.';
      msg.classList.add('show', 'error');
    }
    btn.disabled = false;
    btn.textContent = '💾 Simpan Profil';
  });

  // ── Load admin users ───────────────────────────────────────────────────────
  async function loadUsers() {
    const loading = document.getElementById('usersLoading')!;
    const card = document.getElementById('usersTableCard')!;
    const tbody = document.getElementById('usersTableBody')!;
    loading.style.display = 'block';
    card.style.display = 'none';

    try {
      const res = await fetch('/api/admin/users', { credentials: 'same-origin' });
      if (!res.ok) throw new Error();
      const users = await res.json();

      tbody.innerHTML = '';
      if (users.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; color:#475569; padding:30px;">Belum ada admin terdaftar</td></tr>';
      } else {
        users.forEach((u: any) => {
          const date = new Date(u.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' });
          const statusClass = u.status === 'active' ? 'status-active' : u.status === 'pending' ? 'status-pending' : 'status-disabled';
          const statusText = u.status === 'active' ? 'Aktif' : u.status === 'pending' ? 'Menunggu' : 'Nonaktif';

          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td style="color:#e2e8f0; font-weight:500;">${u.name || '—'}</td>
            <td>${u.email}</td>
            <td><span class="badge ${statusClass}">${statusText}</span></td>
            <td>${date}</td>
            <td>
              <div class="actions">
                ${u.status === 'pending' ? `<button class="btn btn-primary btn-sm approve-btn" data-id="${u.id}">✓ Setujui</button>` : ''}
                ${u.status === 'active' ? `<button class="btn btn-warning btn-sm disable-btn" data-id="${u.id}">Nonaktifkan</button>` : ''}
                ${u.status === 'disabled' ? `<button class="btn btn-primary btn-sm approve-btn" data-id="${u.id}">Aktifkan</button>` : ''}
                <button class="btn btn-secondary btn-sm reset-pw-btn" data-id="${u.id}" data-email="${u.email}">🔑 Reset Password</button>
                <button class="btn btn-danger btn-sm remove-btn" data-id="${u.id}" data-email="${u.email}">Hapus</button>
              </div>
            </td>
          `;
          tbody.appendChild(tr);
        });

        // Attach event handlers
        tbody.querySelectorAll('.approve-btn').forEach(btn => {
          btn.addEventListener('click', () => updateUserStatus((btn as HTMLElement).dataset.id!, 'active'));
        });
        tbody.querySelectorAll('.disable-btn').forEach(btn => {
          btn.addEventListener('click', () => updateUserStatus((btn as HTMLElement).dataset.id!, 'disabled'));
        });
        tbody.querySelectorAll('.remove-btn').forEach(btn => {
          btn.addEventListener('click', async () => {
            const email = (btn as HTMLElement).dataset.email;
            if (!confirm(`Hapus admin "${email}"?\nTindakan ini tidak bisa dibatalkan.`)) return;
            const res = await fetch('/api/admin/users', {
              method: 'DELETE',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ userId: Number((btn as HTMLElement).dataset.id) }),
              credentials: 'same-origin',
            });
            if (res.ok) loadUsers();
            else alert('Gagal menghapus admin.');
          });
        });
        tbody.querySelectorAll('.reset-pw-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const userId = (btn as HTMLElement).dataset.id!;
            const email = (btn as HTMLElement).dataset.email!;
            resetPassword(userId, email);
          });
        });
      }

      loading.style.display = 'none';
      card.style.display = 'block';
    } catch {
      loading.textContent = 'Gagal memuat data admin. Pastikan database terhubung.';
      loading.style.color = '#f87171';
    }
  }

  async function updateUserStatus(userId: string, status: string) {
    const res = await fetch('/api/admin/users', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ userId: Number(userId), status }),
      credentials: 'same-origin',
    });
    if (res.ok) loadUsers();
    else alert('Gagal mengubah status admin.');
  }

  async function resetPassword(userId: string, email: string) {
    const newPassword = prompt(`Reset password untuk "${email}"\n\nMasukkan password baru (minimal 6 karakter):`);
    if (!newPassword) return;
    if (newPassword.length < 6) {
      alert('Password minimal 6 karakter.');
      return;
    }
    const confirmPw = confirm(`Yakin reset password untuk "${email}"?\n\nPassword baru akan langsung aktif.`);
    if (!confirmPw) return;
    try {
      const res = await fetch('/api/admin/reset-password', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: Number(userId), newPassword }),
        credentials: 'same-origin',
      });
      if (res.ok) {
        alert(`✅ Password untuk "${email}" berhasil direset!`);
      } else {
        const data = await res.json();
        alert(`❌ Gagal: ${data.error || 'Unknown error'}`);
      }
    } catch {
      alert('❌ Gagal terhubung ke server.');
    }
  }
</script>
</body>
</html>
